# PostgreSQL (app database)
POSTGRES_PASSWORD=databot_dev

# ON24 master DB (direct read-only access — Google Cloud SQL)
ON24_DB_URL=postgresql+asyncpg://USER:PASS@HOST:PORT/on24master
DB_PG_SSL_ROOT_CERT_CONTENT=
DB_PG_SSL_CERT_CONTENT=
DB_PG_SSL_KEY_CONTENT=

# ON24 REST API
ON24_CLIENT_ID=
ON24_ACCESS_TOKEN_KEY=
ON24_ACCESS_TOKEN_SECRET=

# Anthropic
ANTHROPIC_API_KEY=

# App
DEBUG=true
