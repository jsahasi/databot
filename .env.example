# =============================================================================
# DataBot Environment Configuration
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — it is the single source of truth for all secrets.
# docker compose reads it via env_file; config.py loads both .env and .env.local
# =============================================================================

# --- MCP Settings ---
USE_MCP=Y
USE_MCP_BLOCKLIST="create_event,update_event,add_registrant,remove_registrant,copy_webinar,create_webinar,edit_webinar,update_webinar,delete_webinar,update_event_registrant,update_client_registrant,forget_registrant,forget_all_event_registrants,forget_all_workspace_registrants,create_survey_questions,delete_speaker_bios,delete_vtt_files,update_calendar_reminder,update_email_notification,update_text_with_banner"

# --- Transcription ---
TRANSCRIPTION_PROVIDER=azure
AZURE_SPEECH_KEY=your-azure-speech-key-here
AZURE_SPEECH_REGION=your-azure-region

# --- LLM / Video Generation ---
LLM_PROVIDER=anthropic
VIDEO_GENERATION_PROVIDER=runwayml

# --- Media Library API Keys ---
PIXABAY_KEY=your-pixabay-key-here
FREESOUND_KEY=your-freesound-key-here
RUNWAYML_API_KEY=your-runwayml-key-here

# --- Anthropic ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- OpenAI (used for embeddings in knowledge base) ---
OPENAI_API_KEY=your-openai-api-key-here

# --- ON24 REST API (PROD) ---
ON24_BASE_URL=https://apiqa.on24.com
ON24_ACCESS_TOKEN_KEY=your-on24-token-key-here
ON24_ACCESS_TOKEN_SECRET=your-on24-token-secret-here
ON24_CLIENT_ID=10710

# --- Database: DataBot local Postgres ---
# Docker compose overrides this with the internal hostname (postgres:5432)
# Host port is 5433 to avoid conflict with other local Postgres instances
DATABASE_URL=postgresql+asyncpg://databot:databot_dev@localhost:5433/databot
POSTGRES_PASSWORD=databot_dev

# --- Database: ON24 Master (read-only, requires VPN / ON24 internal network) ---
# PROD: port 5458  |  QA: port 5459
ON24_DB_URL=postgresql+asyncpg://ON24_RO:your-on24-db-password@10.3.7.233:5458/on24master

# SSL certificates for ON24 DB connection (paste full PEM content)
DB_PG_SSL_ROOT_CERT_CONTENT=-----BEGIN CERTIFICATE-----\nyour-ca-cert-here\n-----END CERTIFICATE-----
DB_PG_SSL_CERT_CONTENT=-----BEGIN CERTIFICATE-----\nyour-client-cert-here\n-----END CERTIFICATE-----
DB_PG_SSL_KEY_CONTENT=-----BEGIN PRIVATE KEY-----\nyour-client-key-here\n-----END PRIVATE KEY-----

# --- App Settings ---
DEBUG=true

# --- Claude Code ---
CLAUDE_CODE_MAX_OUTPUT_TOKENS=32000
